# =========================
# APP CONFIG
# =========================
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/gmsai

# =========================
# DATABASE - LOCAL
# =========================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gmsai
DB_USERNAME=root
DB_PASSWORD=

# =========================
# DATABASE - PRODUCTION
# =========================
PROD_DB_CONNECTION=mysql
PROD_DB_HOST=your_production_host
PROD_DB_PORT=3306
PROD_DB_DATABASE=your_production_db
PROD_DB_USERNAME=your_production_user
PROD_DB_PASSWORD=your_production_password

# =========================
# SMTP CONFIG
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=GMSAI System

# =========================
# SECURITY
# =========================
APP_KEY=base64:random_generated_key_here
SESSION_LIFETIME=120


RATE_LIMIT_BYPASS_IPS="127.0.0.1, ::1, 192.168.68.108"